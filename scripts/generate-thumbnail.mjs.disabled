#!/usr/bin/env node
/**
 * 記事サムネイル自動生成スクリプト
 *
 * 使い方:
 *   node scripts/generate-thumbnail.mjs "Notionで社内wikiを作る方法"
 *
 * やること:
 *   1. Gemini Imagen API で画像生成
 *   2. microCMS メディアにアップロード
 *   3. アップロード後の URL を標準出力に返す
 */

import { readFileSync } from "fs";
import { resolve, dirname } from "path";
import { fileURLToPath } from "url";

// .env / .env.local を読み込む（両方あれば .env.local が優先）
const __dirname = dirname(fileURLToPath(import.meta.url));

const parseEnv = (filePath) => {
  try {
    return Object.fromEntries(
      readFileSync(filePath, "utf-8")
        .split("\n")
        .filter((line) => line && !line.startsWith("#") && line.includes("="))
        .map((line) => {
          const idx = line.indexOf("=");
          return [line.slice(0, idx).trim(), line.slice(idx + 1).trim()];
        }),
    );
  } catch {
    return {};
  }
};

const envVars = {
  ...parseEnv(resolve(__dirname, "../.env")),
};

const GEMINI_API_KEY = envVars.GEMINI_API_KEY;
const MICROCMS_API_KEY = envVars.MICROCMS_API_KEY;
const MICROCMS_SERVICE_DOMAIN = envVars.MICROCMS_SERVICE_DOMAIN;

if (!GEMINI_API_KEY || GEMINI_API_KEY.includes("ここに")) {
  console.error("ERROR: .env.local に GEMINI_API_KEY を設定してください");
  process.exit(1);
}
if (!MICROCMS_API_KEY || MICROCMS_API_KEY.includes("ここに")) {
  console.error("ERROR: .env.local に MICROCMS_API_KEY を設定してください");
  process.exit(1);
}

const articleTitle = process.argv[2];
if (!articleTitle) {
  console.error(
    'Usage: node scripts/generate-thumbnail.mjs "記事タイトルまたはテーマ"',
  );
  process.exit(1);
}

// サムネイル用の画像生成プロンプト
const imagePrompt = [
  `Professional blog thumbnail for a Japanese business article titled "${articleTitle}".`,
  "Clean, modern editorial style. Flat illustration or minimalist design.",
  "Business / IT / digital transformation theme.",
  "Soft colors, white or light gray background, subtle geometric shapes.",
  "Wide format (16:9). No text in the image.",
].join(" ");

console.error(`[1/3] 画像生成中... (Gemini 2.0 Flash)`);

// 1. Gemini 2.0 Flash で画像生成
const imagenRes = await fetch(
  `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent?key=${GEMINI_API_KEY}`,
  {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      contents: [{ parts: [{ text: imagePrompt }] }],
      generationConfig: { responseModalities: ["IMAGE"] },
    }),
  },
);

const imagenData = await imagenRes.json();
if (!imagenRes.ok) {
  console.error("Gemini API エラー:", JSON.stringify(imagenData, null, 2));
  process.exit(1);
}

const inlineData = imagenData.candidates?.[0]?.content?.parts?.find(
  (p) => p.inlineData
)?.inlineData;

if (!inlineData?.data) {
  console.error(
    "画像データが取得できませんでした:",
    JSON.stringify(imagenData, null, 2),
  );
  process.exit(1);
}

const imageBuffer = Buffer.from(inlineData.data, "base64");
const mimeType = inlineData.mimeType ?? "image/png";
const ext = mimeType.split("/")[1] ?? "png";

console.error(`[2/3] microCMS にアップロード中...`);

// 2. microCMS メディアAPIにアップロード
const formData = new FormData();
formData.append(
  "file",
  new Blob([imageBuffer], { type: mimeType }),
  `thumbnail.${ext}`,
);

const uploadRes = await fetch(
  `https://${MICROCMS_SERVICE_DOMAIN}.microcms.io/api/v1/media`,
  {
    method: "POST",
    headers: { "X-MICROCMS-API-KEY": MICROCMS_API_KEY },
    body: formData,
  },
);

const uploadData = await uploadRes.json();
if (!uploadRes.ok) {
  console.error(
    "microCMS アップロードエラー:",
    JSON.stringify(uploadData, null, 2),
  );
  process.exit(1);
}

console.error(`[3/3] 完了!`);

// URL を標準出力に出力（他のスクリプトから利用しやすいように）
console.log(uploadData.url);
